# Backend Dockerfile — Python 3.11, FastAPI + uvicorn.
FROM python:3.11-slim AS backend

ENV PYTHONUNBUFFERED=1 \
    PYTHONDONTWRITEBYTECODE=1 \
    PIP_NO_CACHE_DIR=1 \
    PIP_DISABLE_PIP_VERSION_CHECK=1

# System deps for cryptography / bcrypt / motor wheels on slim image.
RUN apt-get update && apt-get install -y --no-install-recommends \
        build-essential curl ca-certificates && \
    rm -rf /var/lib/apt/lists/*

WORKDIR /app/backend

# Strip Emergent-private packages (emergentintegrations is on a private CDN,
# litellm here uses a private wheel URL) before public-PyPI install. They're
# only needed for LLM_PROVIDER=emergent which is irrelevant on a self-hosted VPS.
RUN pip install --no-cache-dir uvicorn
COPY backend/requirements.txt ./requirements.full.txt
RUN grep -v -E "^(emergentintegrations|litellm @)" requirements.full.txt > requirements.txt && \
    pip install --upgrade pip && \
    pip install -r requirements.txt && \
    # Safety net — ensure these core runtime deps are present even if
    # requirements.txt drifts in a future change.
    pip install "uvicorn[standard]>=0.25" "fastapi>=0.110" && \
    # Optional: try to install emergentintegrations from its private CDN.
    # If it fails (e.g. VPS can't reach the CDN), keep going — the
    # llm_provider abstraction falls back to LLM_PROVIDER=direct cleanly.
    (pip install emergentintegrations --extra-index-url https://d33sy5i8bnduwe.cloudfront.net/simple/ || \
     echo "emergentintegrations not installed (OK if LLM_PROVIDER=direct)")

COPY backend/ ./

EXPOSE 8001
CMD ["python", "-m", "uvicorn", "server:app", "--host", "0.0.0.0", "--port", "8001"]
